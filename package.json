{
  "name": "devops-weekly-agent",
  "version": "2.0.0",
  "description": "Executive Slide Rendering Engine — DevOps weekly status as professional HTML/PNG slides",
  "main": "dist/agent.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "tsc && node dist/server.js",
    "dev": "tsc && node --watch dist/server.js",
    "generate": "tsc && node dist/agent.js",
    "clean": "rm -rf dist output"
  },
  "keywords": [
    "github",
    "copilot",
    "sdk",
    "devops",
    "weekly-report",
    "executive-slide",
    "puppeteer"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@github/copilot-sdk": "^0.1.23",
    "@hono/node-server": "^1.19.9",
    "hono": "^4.11.9",
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3"
  }
}
